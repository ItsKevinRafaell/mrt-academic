# Server
PORT=9090

# Database
DATABASE_URL=postgres://mrt:secret@localhost:5432/mrt_db?sslmode=disable

# Auth
JWT_SECRET=change-this-in-production

# CORS - comma-separated list of allowed origins (optional, defaults to localhost)
ALLOWED_ORIGINS=http://localhost:3000,https://your-production-domain.com

# Rate Limiting - requests per minute per IP (optional, defaults to 100)
RATE_LIMIT_RPM=100

# Cache TTL (optional)
SEARCH_CACHE_TTL=5m
DASHBOARD_CACHE_TTL=1m

# External Services (optional)
FONNTE_TOKEN=

# Google Calendar (Service Account)
# 1. Create Google Cloud Project → Enable Calendar API
# 2. Create Service Account → download JSON key → paste content below
# 3. Share your Google Calendar with the service account email (editor access)
# 4. Set GOOGLE_CAL_ID to the calendar ID (found in Calendar Settings → Integrate calendar)
GOOGLE_CAL_JSON_KEY=
GOOGLE_CAL_ID=

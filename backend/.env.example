# Server
PORT=9090

# Database
DATABASE_URL=postgres://mrt:secret@localhost:5432/mrt_db?sslmode=disable

# Auth
JWT_SECRET=change-this-in-production

# CORS - comma-separated list of allowed origins (optional, defaults to localhost)
ALLOWED_ORIGINS=http://localhost:3000,https://your-production-domain.com

# Rate Limiting - requests per minute per IP (optional, defaults to 100)
RATE_LIMIT_RPM=100

# Cache TTL (optional)
SEARCH_CACHE_TTL=5m
DASHBOARD_CACHE_TTL=1m

# External Services (optional)
FONNTE_TOKEN=
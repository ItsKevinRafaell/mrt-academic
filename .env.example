# MRT Academic - VPS Deployment
# Copy this to .env and fill in the values

# Domain (for Caddy auto-HTTPS)
# Set to your domain, e.g., mrt.yourdomain.com
# Leave as localhost for local dev (no HTTPS)
DOMAIN=localhost

# PostgreSQL
POSTGRES_DB=mrt_db
POSTGRES_USER=mrt
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# Auth
JWT_SECRET=CHANGE_THIS_AT_LEAST_32_CHARACTERS_LONG

# Fonnte (WhatsApp Notification)
# Get token from https://fonnte.com
FONNTE_TOKEN=

# Frontend API URL (for build time)
# For production: use your domain
# For local: http://backend:9090/api/v1
NEXT_PUBLIC_API_URL=http://backend:9090/api/v1
